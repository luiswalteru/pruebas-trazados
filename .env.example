# Copy to .env.local and fill in. .env.local is git-ignored by Vite.

# =============================================================================
# SAM 2 via Replicate (provider "sam")
# =============================================================================
# Replicate API token — used by /__sam-segment to call SAM 2 for letter-body
# segmentation. Without this, the SAM provider option is disabled.
# Get one at https://replicate.com/account/api-tokens.
REPLICATE_API_TOKEN=

# Optional fallback SAM model slug (first tried by the drawer). You can also
# manage the priority list from the UI at Step 2.
# VITE_SAM_MODEL=meta/sam-2

# =============================================================================
# Claude (Anthropic) vision (provider "claude")
# =============================================================================
# Anthropic API key — used by /__claude-segment to ask Claude vision for the
# letter centerline as a JSON segment list. Without this, the Claude provider
# option is disabled.
# Get one at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=

# Optional override (default: claude-sonnet-4-6). Use claude-haiku-4-5-20251001
# for cheaper/faster but less accurate vision, or claude-opus-4-7 for highest
# quality.
# VITE_CLAUDE_MODEL=claude-sonnet-4-6

# =============================================================================
# Gemini (Google) vision (provider "gemini") — RECOMMENDED for free usage
# =============================================================================
# Google AI Studio API key — used by /__gemini-segment. Gemini Flash has a
# generous free tier (1500 req/day, 15 req/min) with no credit card needed.
# Get one at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# Optional override (default: gemini-2.5-flash). gemini-2.5-pro is more
# accurate but slower and counts against a smaller free quota.
# VITE_GEMINI_MODEL=gemini-2.5-flash
